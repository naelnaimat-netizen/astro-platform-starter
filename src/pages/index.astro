---
import Layout from '../layouts/Layout.astro';
import Markdown from '../components/Markdown.astro';

const explainer = `
Welcome to **Sigma Academy** - your gateway to understanding the universe through the lens of science and spirituality.

We explore the fascinating connections between **Quantum Physics**, **Mathematics**, **Science**, and the **Holy Quran**, revealing the harmony between modern scientific discoveries and ancient wisdom.

Our courses and resources are designed to inspire curiosity, deepen understanding, and bridge the gap between scientific inquiry and spiritual enlightenment.
`;
---

<Layout title="Sigma Academy - Quantum Physics, Math & Science">
    <h1 class="mb-10">Welcome to Sigma Academy</h1>
    <Markdown content={explainer} class="mb-10 text-lg" />
    <div class="grid gap-6 md:grid-cols-3 mb-10">
        <div class="bg-white/10 rounded-lg p-6">
            <h3 class="text-xl font-bold mb-2">🔬 Quantum Physics</h3>
            <p class="text-sm opacity-80">Explore the mysteries of the quantum realm and its profound implications.</p>
        </div>
        <div class="bg-white/10 rounded-lg p-6">
            <h3 class="text-xl font-bold mb-2">📐 Mathematics</h3>
            <p class="text-sm opacity-80">Discover the universal language that describes our reality.</p>
        </div>
        <div class="bg-white/10 rounded-lg p-6">
            <h3 class="text-xl font-bold mb-2">📖 Science & Faith</h3>
            <p class="text-sm opacity-80">Bridge the connection between scientific knowledge and spiritual wisdom.</p>
        </div>
    </div>
    <p>
        <a href="/blobs" class="btn btn-lg sm:min-w-64">Explore Our Resources</a>
    </p>
</Layout>
