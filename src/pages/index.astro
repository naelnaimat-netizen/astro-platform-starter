---
import logic from '../logic-core.json';
---
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{logic.title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body style="background:#000; color:#0f0; font-family:monospace; padding:40px;">
  <header style="border-bottom: 2px solid #0f0; margin-bottom: 20px;">
    <h1>SYSTEM: {logic.title}</h1>
    <p>CORE: {logic.philosophy}</p>
  </header>
  <main>
    <div style="border: 1px solid #0f0; padding: 20px;">
      <h2>Current Protocol:</h2>
      {logic.daily_check.map(item => <p>[✓] {item}</p>)}
    </div>
  </main>
</body>
</html>
