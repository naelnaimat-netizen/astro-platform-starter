---
import Layout from '../layouts/Layout.astro';
import Markdown from '../components/Markdown.astro';

const explainer = `
Welcome to Sigmaacadmy - your platform for learning and growth.

Built with modern web technologies including [Astro](https://astro.build/) and [Netlify](https://netlify.com/), 
Sigmaacadmy delivers fast, reliable content with cutting-edge performance.
`;
---

<Layout title="Welcome to Sigmaacadmy">
    <h1 class="mb-10">Welcome to Sigmaacadmy</h1>
    <Markdown content={explainer} class="mb-10 text-lg" />
    <p>
        <a href="https://sigmaacadmy.com" class="btn btn-lg sm:min-w-64">Visit Sigmaacadmy.com</a>
    </p>
</Layout>
